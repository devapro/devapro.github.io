article
  background color-surface
  border 1px solid color-border
  border-radius radius
  margin-bottom 26px
  position relative
  overflow hidden
  transition border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease

  // legacy FontAwesome file glyph — retired in the modern layout
  .icon
    display none

  // listing cards (index / archive / tag / category) lift on hover
  &:has(.title a)
    &:hover
      border-color rgba(56, 189, 248, 0.45)
      transform translateY(-3px)
      box-shadow 0 14px 36px -18px rgba(0, 0, 0, 0.75)

  .post-content
    padding 30px 34px
    @media screen and (max-width: 600px)
      padding 22px 20px

  .gallery
    overflow hidden
    position relative
    &:hover
      .control
        opacity 1
    img
      min-width 100%
      max-width 100%
      height auto
      position absolute
      top 0
      left 0
      opacity 0
    .control
      opacity 0
      transition 0.3s
    .prev, .next
      position absolute
      top 0
      width 50%
      height 100%
      cursor pointer
      &:before
        position absolute
        font 24px/1 font-icon
        text-align center
        width 24px
        text-shadow 0 0 15px rgba(0,0,0,0.5)
        color #fff
        margin-top -12px
        top 50%
    .prev
      left 0
      &:before
        content '\f053'
        left 10px
    .next
      right 0
      &:before
        content '\f054'
        right 10px

  header
    time
      color color-meta
      font 0.8em font-mono
      letter-spacing 0.02em
      margin-bottom 12px
      display block
      line-height 1
      a
        color color-meta
        &:hover
          color color-accent
      &:before
        content '\f017'
        font-family font-icon
        margin-right 8px
        color color-accent
        opacity 0.8

    .title
      font-weight 700
      font-size 1.55em
      letter-spacing -0.02em
      line-height 1.2
      a
        color color-heading
        &:hover
          color color-accent
          text-decoration none

  .entry
    line-height 1.75
    p, blockquote, ul, ol, dl, table, iframe, h2, h3, h4, h5, h6, .video-container, figure.highlight, pre
      margin-top 18px

    a
      color color-link
      text-decoration none
      border-bottom 1px solid rgba(56, 189, 248, 0.35)
      &:hover
        border-bottom-color color-accent

    table
      border-collapse collapse
      border-spacing 0
      empty-cells show
      width 100%
      font-size 0.94em
      border 1px solid color-border
      border-radius radius-sm
      overflow hidden
      th
        white-space nowrap
        color color-heading
        font-weight 600
        background color-surface-3
      td, th
        border 1px solid color-border
        padding 10px 16px
        text-align left
      tr:hover td
        background rgba(255, 255, 255, 0.02)

    figure.highlight
      table
        border none
        width auto
        border-collapse separate

    blockquote
      border-left 3px solid color-accent
      background color-surface-2
      border-radius 0 radius-sm radius-sm 0
      font-style italic
      color color-font
      padding 14px 24px
      footer
        border-top none
        font-style normal
        font-size 0.85em
        line-height 1
        margin 14px 0 0
        padding-top 0
        color color-meta
        cite
          &:before
            content '—'
            color color-meta
            padding 0 0.5em

    code, pre
      font-family font-mono

    // inline code
    code
      background color-surface-2
      color #e2b8ff
      padding 2px 7px
      margin 0 1px
      font-size 0.86em
      border 1px solid color-border
      border-radius 6px

    pre
      background code-bg
      border 1px solid color-border
      color color-font
      overflow auto
      padding 16px 18px
      border-radius radius-sm
      font-size 0.88em
      line-height 1.6
      code
        background none
        padding 0
        margin 0
        border none
        border-radius 0
        color inherit

    ul, ol, dl
      margin-left 22px
      ul, ol, dl
        margin-top 6px
    li
      margin-top 6px
      &::marker
        color color-accent

    h2, h3, h4, h5, h6
      color color-heading
      font-weight 600
      scroll-margin-top 90px

    h1, h2
      border-bottom 1px solid color-border
      padding-bottom 10px
      margin-top 30px

    img, video
      max-width 100%
      height auto
      border 1px solid color-border
      border-radius radius-sm

    iframe
      border none

    .caption
      display block
      margin-top 6px
      color color-meta
      position relative
      font-size 0.88em
      padding-left 25px
      &:before
        content '\f040'
        position absolute
        font 1.2em font-icon
        left 0
        top 3px

    .video-container
      position relative
      padding-bottom 56.25%
      padding-top 30px
      height 0
      overflow hidden
      iframe, object, embed
        position absolute
        top 0
        left 0
        width 100%
        height 100%
        margin-top 0

    .pullquote
      float right
      border none
      background none
      padding 0
      margin 1em 0 0.5em 1.5em
      text-align left
      width 45%
      font-size 1.4em

  footer
    margin-top 22px
    padding 18px 34px
    border-top 1px solid color-border-soft
    background color-surface-2
    color color-meta
    font-size 0.88em
    line-height 1.6
    position relative
    @media screen and (max-width: 600px)
      padding 16px 20px

    a
      color color-meta
      &:hover
        color color-accent
        text-decoration none

    // "Read More" call to action
    .more-link
      display inline-flex
      align-items center
      gap 8px
      padding 8px 16px
      border 1px solid color-border
      border-radius radius-pill
      color color-accent
      font-weight 500
      background color-surface
      &:hover
        border-color color-accent
        background rgba(56, 189, 248, 0.08)
      &:before
        content '\f061'
        font 0.95em font-icon

    .comment-link
      &:before
        content '\f075'
        font 1em font-icon
        padding-right 8px
        vertical-align middle

    // categories & tags as pills
    .categories, .tags
      display flex
      flex-wrap wrap
      align-items center
      gap 8px
      margin 6px 0
      a
        display inline-block
        padding 4px 12px
        border-radius radius-pill
        font-size 0.92em
        font-family font-mono
        background color-surface-3
        border 1px solid color-border
        color color-font
        &:hover
          border-color color-accent
          color color-accent
    .categories
      &:before
        content '\f07b'
        font 0.95em font-icon
        color color-meta
      a:before
        content ''
    .tags
      &:before
        content '\f02b'
        font 0.92em font-icon
        color color-meta
      a:before
        content '#'
        color color-accent
        margin-right 1px

    .translations
      display flex
      flex-wrap wrap
      align-items center
      gap 10px
      margin-top 18px
      padding 12px 16px
      background color-surface
      border 1px solid color-border
      border-left 3px solid color-accent-2
      border-radius radius-sm
      span
        font-weight 600
        color color-heading
      .translation-link
        color color-accent-2
        font-family font-mono
        font-size 0.92em
        &:hover
          color lighten(color-accent-2, 12%)
          text-decoration none

  // page layout (about / static pages) — no leading icon offset
  &.page
    .post-content
      padding 30px 34px
