.entry
  .gist
    background code-bg
    border 1px solid color-border
    border-radius radius-sm
    margin-top 18px
    padding 14px 16px
    line-height 1.6
    overflow auto
    color color-font
    .gist-file
      border none
      font-family inherit
      margin 0
      font-size 0.88em
      .gist-data
        background none
        border-bottom none
        pre
          padding 0 !important
          font-family font-mono
      .gist-meta
        background none
        color color-meta
        margin-top 8px
        padding 0
        font-size 100%
        a
          color color-link
          &:visited
            color color-link

figure.highlight
  background code-bg
  border 1px solid color-border
  border-radius radius-sm
  margin-top 18px
  padding 14px 16px
  line-height 1.6
  overflow auto
  position relative
  font-size 0.88em
  color color-font

  figcaption
    color color-meta
    margin-bottom 10px
    font-family font-mono
    font-size 0.9em
    a
      position absolute
      right 16px
      color color-accent

  pre
    border none
    padding 0
    margin 0
    background none

  table
    margin-top 0
    border-spacing 0

  .gutter
    color color-meta
    opacity 0.55
    padding 0
    padding-right 16px
    border 0
    border-right 1px solid color-border
    text-align right
    user-select none

  .code
    padding-left 16px
    border 0
    color color-font

  .line
    height 20px

  .line.marked
    background rgba(56, 189, 248, 0.10)

// ── Token colors — One Dark ───────────────────────────────────
pre
  .comment
  .template_comment
  .diff .header
  .doctype
  .pi
  .lisp .string
  .javadoc
    color syn-comment
    font-style italic

  .keyword
  .winutils
  .method
  .addition
  .css .tag
  .request
  .status
  .nginx .title
    color syn-keyword

  .number
  .command
  .hexcolor
  .tex .formula
    color syn-number

  .string
  .tag .value
  .phpdoc
  .regexp
  .markdown .value
    color syn-string

  .title
  .localvars
  .chunk
  .decorator
  .built_in
  .identifier
  .vhdl
  .literal
  .id
    color syn-func

  .attribute
  .variable
  .lisp .body
  .smalltalk .number
  .constant
  .class .title
  .parent
  .haskell .type
    color syn-class

  .preprocessor
  .preprocessor .keyword
  .shebang
  .symbol
  .symbol .string
  .diff .change
  .special
  .attr_selector
  .important
  .subst
  .cdata
  .clojure .title
    color syn-cyan

  .tag
  .tag .title
  .css .class
  .css .id
    color syn-red

  .deletion
    color syn-red
