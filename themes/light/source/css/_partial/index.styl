#pagination
  display flex
  align-items center
  justify-content space-between
  margin-bottom 60px
  font-family font-mono
  a
    float none
    display inline-flex
    align-items center
    gap 8px
    padding 10px 18px
    background color-surface
    border 1px solid color-border
    border-radius radius-pill
    color color-font
    font-size 0.92em
    transition all 0.18s ease
    &:hover
      border-color color-accent
      color color-accent
      background rgba(56, 189, 248, 0.07)
      text-decoration none

  .prev
    &:before
      content '\f060'
      font-family font-icon
      font-size 0.9em
  .next
    margin-left auto
    &:after
      content '\f061'
      font-family font-icon
      font-size 0.9em
